# API configuration
BAIDU_OCR_API_KEY=your-baidu-ocr-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-ocr-secret-key

# Doubao / Volcengine Ark configuration
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_MODEL_ID=doubao-seed-2-0-lite-260428

# Email configuration. Use a mailbox app password or SMTP authorization code.
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=your_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code

# App configuration
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,bmp
LOG_LEVEL=INFO
